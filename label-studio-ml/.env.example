# Label Studio ML Backend — configuración de entorno
# Copia este fichero como .env y rellena los valores reales
# NO subas el .env al repositorio

# URL de Label Studio accesible desde dentro del contenedor Docker
# En Docker Desktop (Windows/Mac) usar host.docker.internal en lugar de localhost
LABEL_STUDIO_HOST=http://host.docker.internal:8080

# Token de API de Label Studio
# Obtenerlo en: Label Studio → Account & Settings → Access Token
# O directamente de la BD SQLite:
#   SELECT key FROM authtoken_token LIMIT 1;
#   BD: %APPDATA%\Local\label-studio\label-studio\label_studio.sqlite3
LABEL_STUDIO_ACCESS_TOKEN=<tu_token_aqui>
